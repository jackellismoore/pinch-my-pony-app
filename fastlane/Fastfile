# fastlane/Fastfile

opt_out_usage
default_platform(:ios)

platform :ios do
  desc "ONE-TIME: create signing certs/profiles and store in match repo"
  lane :bootstrap do
    user = ENV["FASTLANE_USER"] || ENV["FASTLANE_USERNAME"] || ENV["APPLE_ID"]
    UI.user_error!("Missing FASTLANE_USER (or FASTLANE_USERNAME/APPLE_ID) env var") unless user && !user.strip.empty?

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_P8"],
      is_key_content_base64: true
    )

    match(
      type: "appstore",
      git_url: ENV["MATCH_GIT_URL"],
      readonly: false,
      username: user,
      api_key: api_key
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    user = ENV["FASTLANE_USER"] || ENV["FASTLANE_USERNAME"] || ENV["APPLE_ID"]
    UI.user_error!("Missing FASTLANE_USER (or FASTLANE_USERNAME/APPLE_ID) env var") unless user && !user.strip.empty?

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_P8"],
      is_key_content_base64: true
    )

    # Pull signing (readonly) from match
    match(
      type: "appstore",
      git_url: ENV["MATCH_GIT_URL"],
      readonly: true,
      username: user,
      api_key: api_key
    )

    # Build the iOS app (Capacitor projects typically use "App")
    build_app(
      scheme: ENV["IOS_SCHEME"] || "App",
      export_method: "app-store"
    )

    upload_to_testflight(api_key: api_key)
  end
end