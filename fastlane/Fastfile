default_platform(:ios)

platform :ios do
  private_lane :api_key do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_P8"],
      is_key_content_base64: false
    )
  end

  desc "ONE-TIME: create signing certs/profiles and store in match repo"
  lane :bootstrap do
    match(type: "appstore", git_url: ENV["MATCH_GIT_URL"], readonly: false)
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    key = api_key()
    match(type: "appstore", git_url: ENV["MATCH_GIT_URL"], readonly: true)

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store"
    )

    upload_to_testflight(api_key: key)
  end
end
