opt_out_usage

require "base64"

default_platform(:ios)

platform :ios do
  def asc_api_key
    key = ENV["ASC_KEY_P8"].to_s

    # Some people store the .p8 as base64 in GitHub Secrets.
    # Support both raw PEM and base64-encoded PEM.
    if !key.include?("BEGIN PRIVATE KEY")
      key = Base64.decode64(key)
    end

    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: key,
      in_house: false
    )
  end

  desc "Bootstrap certificates and provisioning profiles"
  lane :bootstrap do
    api_key = asc_api_key

    match(
      type: "appstore",
      readonly: false,
      api_key: api_key
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = asc_api_key

    match(
      type: "appstore",
      readonly: true,
      api_key: api_key
    )

    build_app(
      scheme: ENV["IOS_SCHEME"] || "App",
      export_method: "app-store",
      clean: true,
      skip_package_dependencies_resolution: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end