cat > fastlane/Fastfile <<'RUBY'
opt_out_usage

require "base64"

default_platform(:ios)

platform :ios do
  def asc_api_key
    key = ENV["ASC_KEY_P8"].to_s

    # Support raw PEM or base64 PEM in GitHub Secrets
    if !key.include?("BEGIN PRIVATE KEY")
      key = Base64.decode64(key)
    end

    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: key,
      in_house: false
    )
  end

  def ci_keychain_name
    n = ENV["MATCH_KEYCHAIN_NAME"].to_s
    n.empty? ? "build.keychain-db" : n
  end

  def ci_keychain_password
    ENV["MATCH_KEYCHAIN_PASSWORD"].to_s
  end

  def ios_workspace
    "ios/App/App.xcworkspace"
  end

  def ios_scheme
    s = ENV["IOS_SCHEME"].to_s
    s.empty? ? "App" : s
  end

  desc "Bootstrap certificates and provisioning profiles"
  lane :bootstrap do
    api_key = asc_api_key

    match(
      type: "appstore",
      readonly: false,
      api_key: api_key,
      keychain_name: ci_keychain_name,
      keychain_password: ci_keychain_password
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = asc_api_key

    match(
      type: "appstore",
      readonly: true,
      api_key: api_key,
      keychain_name: ci_keychain_name,
      keychain_password: ci_keychain_password
    )

    build_app(
      workspace: ios_workspace,
      scheme: ios_scheme,
      export_method: "app-store",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
RUBY