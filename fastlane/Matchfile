# fastlane/Matchfile

git_url(ENV["MATCH_GIT_URL"])
git_branch("main")

type("appstore")
app_identifier(["com.pinchmypony.app"])

# Prevent match from trying to prompt for a username in CI
username(ENV["FASTLANE_USER"] || ENV["FASTLANE_USERNAME"] || ENV["APPLE_ID"])

git_full_name("match-bot")
git_user_email("match-bot@users.noreply.github.com")